<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SharpChat.Core.ViewModels;assembly=SharpChat.Core"
             xmlns:model="clr-namespace:SharpChat.Core.Models;assembly=SharpChat.Core"
             x:Class="SharpChat.Maui.Pages.ChatPage"
             x:DataType="vm:ChatViewModel">

    <Grid RowDefinitions="Auto, *, Auto" 
          ColumnDefinitions="150, 5*, *, *"
          RowSpacing="4"
          ColumnSpacing="8"
          Padding="24, 16">

        <CollectionView Grid.RowSpan="3"
                        ItemsSource="{Binding ChatsList}"
                        HorizontalOptions="Fill"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedChat}">
            
            <CollectionView.ItemTemplate>

                <DataTemplate x:DataType="model:Chat">
                    <VerticalStackLayout Margin="0,0,0,10">

                        <Label Text="{Binding Title}" 
                               FontAttributes="Bold" 
                               TextColor="Black" />

                        <Label Text="{Binding LastMessage.Text}" 
                               TextColor="Gray"
                               LineBreakMode="WordWrap" />

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Column="1"
               Text="{Binding SelectedChat.Title}"
               FontAttributes="Bold"
               FontSize="16"/>

        <Entry Grid.Column="2"
               Grid.ColumnSpan="2"
               IsEnabled="{Binding IsSearchEnabled}"
               Text="{Binding SearchText, Mode=TwoWay}"/>

        <CollectionView Grid.Row="1"
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        ItemsSource="{Binding FilteredMessages}" 
                        WidthRequest="250"
                        HorizontalOptions="Center"
                        SelectionMode="Single">
            <CollectionView.ItemTemplate>

                <DataTemplate x:DataType="model:Message">
                    <VerticalStackLayout Margin="0,0,0,10">

                        <Label Text="{Binding Sender.Username}" 
                               FontAttributes="Bold" 
                               TextColor="Blue" />

                        <Label Text="{Binding Text}" 
                               LineBreakMode="WordWrap" />

                        <Label Text="{Binding Time, StringFormat='{0:HH:mm}'}" 
                               FontSize="10" 
                               TextColor="Gray" />

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Entry Grid.Row="2"
               Grid.Column="1"
               Text="{Binding CurrentMessageText, Mode=TwoWay}"/>

        <Button Text="Submit"
                Grid.Row="2"
                Grid.Column="2"
                Command="{Binding SubmitCommand}"/>

        <Button Text="Cleanup"
                Grid.Row="2"
                Grid.Column="3"
                Command="{Binding CleanupCommand}"/>

    </Grid>
</ContentPage>